# MongoDB
MONGO_URL=mongodb://localhost:27017/pharmacy_db

# Server
PORT=4000
NODE_ENV=development

# CORS — comma-separated frontend origins
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:5173

# JWT — REQUIRED in production (use long random strings)
JWT_SECRET=change_me_in_production_use_64_char_random_string
JWT_REFRESH_SECRET=change_me_refresh_secret_use_different_string
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
BCRYPT_ROUNDS=12

# Default admin (used by npm run seed:admin only)
ADMIN_EMAIL=admin@pharmacare.com
ADMIN_PASSWORD=Admin@123456
ADMIN_NAME=Pharmacy Admin

# Set to false in production to disable public staff sign-up
ALLOW_PUBLIC_SIGNUP=true
